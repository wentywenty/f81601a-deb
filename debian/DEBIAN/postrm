#!/bin/bash
set -e

# Prevent execution during host-side package staging.
if [ "${HOST_BUILD_STAGE:-0}" -eq 1 ]; then
    exit 0
fi

KERNEL_VER="$(uname -r)"
if [ -f "/boot/System.map-$KERNEL_VER" ]; then
    depmod -F "/boot/System.map-$KERNEL_VER" "$KERNEL_VER" || true
else
    depmod -a "$KERNEL_VER" || true
fi

exit 0
